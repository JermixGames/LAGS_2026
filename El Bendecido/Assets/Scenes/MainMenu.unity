  m_text: "\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\nCr\xE9ditos
    del Videojuego\n\nDesarrollo y Dise\xF1o\r\n\r\nProgramaci\xF3n y Mec\xE1nicas\n
    \n[JOS\xC9 MORENO ]\n\n[JEREMY CASTILLO ]\r\n\r\nDise\xF1o de Niveles\n\n[ADRIAN
    AMAYA]\r\n\r\nSistemas de IA y Navegaci\xF3n\n\n[JOS\xC9 MORENO]\r\n\r\nArte
    y Dise\xF1o Visual\n\nDise\xF1o Gr\xE1fico Y MODELADO 3D \n\n[MARIE-CLAIRE PEREZ]\n\r\nInterfaz
    de Usuario (UI)\n\n[JOSE JARQUIN]\r\n\r\nAudio y M\xFAsica\n\r\nComposici\xF3n
    Musical\n\n [JOS\xC9 MORENO]\r\n\r\nDise\xF1o de Sonido y Efectos\n\n [JOS\xC9
    MORENO]\r\n\r\nHerramientas Utilizadas\r\n\nMotor de Juego\n\n[Unity Engine]\r\n\r\nDise\xF1o
    Digital\n\n[Blender]\n\n[Affinity Suite]\r\n\nProducci\xF3n de Audio\n\n[Ableton
    Live / FL Studio]\n"
